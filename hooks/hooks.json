    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop_passive_logging.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/stop_self_audit.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check_propose_discipline.sh\""
          },
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/scripts/check_orphan_ds_css.sh\""
          },
          {
            "type": "command",
            "command": "bash -lc 'cd \"${CLAUDE_PLUGIN_ROOT}\" && node scripts/audit-content-quality.mjs --check 2>&1 | grep -E '\\[P[01]\\]|✅|⚠️' | head -10 || true'"
          },
          {
            "type": "command",
            "command": "bash -lc 'cd \"${CLAUDE_PLUGIN_ROOT}\" && node scripts/extract-canonical-rules.mjs 2>&1 | grep -E 'GAPS|✅|keywords missing' | head -8 || true'"
          }
        ]
      }
