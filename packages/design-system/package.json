{
  "name": "@qijenchen/design-system",
  "version": "0.1.0-beta.54",
  "private": false,
  "description": "World-class design system — components, patterns, tokens, hooks (single source of truth for team distribution).",
  "type": "module",
  "license": "UNLICENSED",
  "files": [
    "dist",
    "src/**/*.{tsx,ts,css}",
    "src/**/*.spec.md",
    "!src/**/*.spec.ts",
    "!src/**/*.test.ts",
    "README.md",
    "CLAUDE.md",
    "ds-canonical",
    "cli-init.mjs",
    "ds-story-manifest.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./patterns/*": {
      "types": "./dist/patterns/*/index.d.ts",
      "import": "./dist/patterns/*/index.js"
    },
    "./tokens/*": "./src/tokens/*",
    "./hooks/*": {
      "types": "./dist/hooks/*.d.ts",
      "import": "./dist/hooks/*.js"
    },
    "./styles/tokens.css": "./src/styles/tokens.css",
    "./styles/tokens": "./src/styles/tokens.css",
    "./package.json": "./package.json",
    "./ds-story-manifest.json": "./ds-story-manifest.json",
    "./styles/base": "./src/styles/base.css"
  },
  "bin": {
    "qijenchen-ds-init": "./cli-init.mjs"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "build": "vite build",
    "build:dts": "tsc -p tsconfig.json && tsc-alias -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.23",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.1.0",
    "embla-carousel-react": "^8.6.0",
    "lucide-react": "^0.577.0",
    "react-day-picker": "^9.14.0",
    "react-is": "^18.0.0 || ^19.0.0",
    "react-zoom-pan-pinch": "^4.0.3",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "tailwindcss": ">=4.0.0"
  },
  "devDependencies": {
    "tsc-alias": "^1.8.17"
  }
}
