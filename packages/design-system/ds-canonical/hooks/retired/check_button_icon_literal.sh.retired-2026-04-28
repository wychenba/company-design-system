#!/bin/bash
# PostToolUse hook: catch literal icon characters in Button content (e.g. "+ 新增").
#
# Per .claude/rules/ui-development.md「Icon canonical」:
# Icon 必須用 lucide-react component(Plus / X / Check / TriangleAlert / Info / etc),
# 不可在 Button label 寫字面 "+" / "-" / "×" / "✓" / "→" 等符號當 icon 用。
#
# Detects: <Button ... >+ XX</Button> / <Button>↗ Open</Button> 等 pattern.

source "$(dirname "$0")/_log-fire.sh" 2>/dev/null && log_hook_fire

FILE_PATH=$(jq -r '.tool_input.file_path // empty')

if ! echo "$FILE_PATH" | grep -qE '\.(tsx|stories\.tsx)$'; then
  exit 0
fi
if [ ! -f "$FILE_PATH" ]; then
  exit 0
fi

# Match Button content starting with a single icon-like character + space
# Examples that violate:
#   <Button>+ 新增</Button>
#   <Button>× Close</Button>
#   <Button>→ Continue</Button>
LITERAL_HITS=$(grep -nE '<Button[^>]*>\s*[-+×✕✗✓→←↑↓↗↖↘↙]\s+' "$FILE_PATH" 2>/dev/null | head -5)

if [ -n "$LITERAL_HITS" ]; then
  ADDITIONAL_CONTEXT=$(printf 'Button label 含字面 icon 字元(請改 lucide-react component):\n%s\n  映射: + → startIcon={Plus} / × → startIcon={X} / → → endIcon={ArrowRight} / ✓ → startIcon={Check}' "$LITERAL_HITS")
  jq -n --arg ctx "$ADDITIONAL_CONTEXT" '{
    hookSpecificOutput: {
      hookEventName: "PostToolUse",
      additionalContext: $ctx
    }
  }'
fi

exit 0
