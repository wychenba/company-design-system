{
  "extends": "../../tsconfig.app.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/design-system/*": ["./src/*"],
      "@/lib/*": ["./src/lib/*"]
    },
    "types": ["vite/client", "node"],
    "noEmit": false,
    "emitDeclarationOnly": true,
    "declaration": true,
    "declarationMap": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "rootDir": "./src",
    "outDir": "./dist"
  },
  "include": ["src"],
  "exclude": [
    "**/*.stories.tsx",
    "**/*.anatomy.stories.tsx",
    "**/*.principles.stories.tsx",
    "**/*.test.ts",
    "**/*.spec.ts"
  ]
}
