{
  "name": "@qijenchen/storybook-config",
  "version": "0.1.0-beta.29",
  "private": false,
  "description": "Shared Storybook config (addons preset + preview parameters + decorators) for design-system + consumer products. Single SSOT for storybook UX.",
  "type": "module",
  "license": "UNLICENSED",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js",
      "require": "./dist/preview.js",
      "default": "./dist/preview.js"
    },
    "./preset": {
      "types": "./dist/addons-preset.d.ts",
      "import": "./dist/addons-preset.js",
      "require": "./dist/addons-preset.js",
      "default": "./dist/addons-preset.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js",
      "require": "./dist/preview.js",
      "default": "./dist/preview.js"
    },
    "./addons/ds-devmode/preset": {
      "types": "./dist/addons/ds-devmode/preset.d.ts",
      "import": "./dist/addons/ds-devmode/preset.js",
      "require": "./dist/addons/ds-devmode/preset.js",
      "default": "./dist/addons/ds-devmode/preset.js"
    },
    "./addons/ds-devmode/manager": {
      "types": "./dist/addons/ds-devmode/manager.d.ts",
      "import": "./dist/addons/ds-devmode/manager.js",
      "require": "./dist/addons/ds-devmode/manager.js",
      "default": "./dist/addons/ds-devmode/manager.js"
    },
    "./addons/ds-devmode/preview": {
      "types": "./dist/addons/ds-devmode/preview.d.ts",
      "import": "./dist/addons/ds-devmode/preview.js",
      "require": "./dist/addons/ds-devmode/preview.js",
      "default": "./dist/addons/ds-devmode/preview.js"
    }
  },
  "main": "./dist/preview.js",
  "types": "./dist/preview.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@storybook/addon-essentials": "^8.6.0",
    "@storybook/addon-a11y": "^8.6.0",
    "@storybook/addon-docs": "^8.6.0",
    "@storybook/addon-links": "^8.6.0"
  },
  "peerDependencies": {
    "@qijenchen/design-system": ">=0.1.0-beta.15",
    "@storybook/react": ">=8.0.0 <11.0.0",
    "@storybook/react-vite": ">=8.0.0 <11.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0"
  }
}
